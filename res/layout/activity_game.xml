<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout is intentionally minimal — the WebView fills the entire screen.
  The WebView is created programmatically in GameActivity.java for
  maximum control over settings, so this layout is a fallback reference.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000008">

    <WebView
        android:id="@+id/gameWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:hardwareAccelerated="true" />

</FrameLayout>
